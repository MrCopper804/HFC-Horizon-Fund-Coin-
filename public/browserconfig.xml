<?xml version="1.0" encoding="utf-8"?>
<!--
  HFC Exchange - Windows Tile configuration (browserconfig.xml)
  Ensures professional branded experience when pinned to Windows Start Screen.
-->
<browserconfig>
  <msapplication>
    <tile>
      <square70x70logo src="/icons/icon-192.png"/>
      <square150x150logo src="/icons/icon-192.png"/>
      <wide310x150logo src="/icons/icon-512.png"/>
      <square310x310logo src="/icons/icon-512.png"/>
      <TileColor>#0d1117</TileColor>
    </tile>
  </msapplication>
</browserconfig>
